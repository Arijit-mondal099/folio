# Copy this file to .env and fill in the values.
# See docs/configuration.md for a full description of each variable.

# === Auth (better-auth) ===
# 32+ character random string. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL where the app is served. Same as NEXT_PUBLIC_SITE_URL for most setups.
BETTER_AUTH_URL=http://localhost:3000


# === Database (Neon Postgres) ===
# Get it from your Neon project dashboard -> Connection Details.
# Format: postgresql://user:password@host/db?sslmode=require
DATABASE_URL=


# === Google OAuth ===
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# === Email (Resend) ===
# Get an API key at https://resend.com/api-keys
# Used for verification and password-reset emails.
RESEND_API_KEY=


# === AI (Groq) ===
# Get an API key at https://console.groq.com/keys
# Powers the chat sidebar and the inline transform toolbar.
GROQ_API_KEY=


# === Public (sent to the browser) ===
# Absolute URL of the deployed site. Used for OG, sitemap, robots.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Better-auth client baseURL. Usually the same as NEXT_PUBLIC_SITE_URL.
# Note: not validated in lib/env.ts (see docs/configuration.md for the open inconsistency).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Reset-password landing URL. Email links navigate here with ?token=...
NEXT_PUBLIC_REDIRECT_TO=http://localhost:3000/reset-password
